{
  "hooks": {
    "NonexistentEvent": [
      {
        "matcher": ".*",
        "hooks": [{ "type": "command", "command": "echo hi" }]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "[invalid regex(",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/dangerous-thing",
            "timeout": 3600
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [{ "type": "prompt", "prompt": "$ARGUMENTS" }]
      }
    ],
    "Notification": [
      {
        "hooks": [{ "type": "prompt", "prompt": "ok?" }]
      }
    ]
  }
}
