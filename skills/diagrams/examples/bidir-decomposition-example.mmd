---
config:
  theme: base
  themeVariables:
    primaryColor: '#ffcccc'
---

%% ANTI-PATTERN: Bi-directional Arrow
%% ====================================

graph LR
    OrderService["OrderService"]
    PaymentService["PaymentService"]

    OrderService <--> PaymentService

    style OrderService fill:#ffe8e8
    style PaymentService fill:#ffe8e8

    Note1["❌ BAD: Hides coupling<br/>Unclear which is sync<br/>Hidden race conditions"]
    style Note1 fill:#ffcccc,color:#000


%% ==========================================
%% SOLUTION 1: Decompose into Two Arrows (C4)
%% ==========================================

graph LR
    subgraph Solution1["✅ SOLUTION 1: Unidirectional Flows (C4 Component)"]
        OS1["OrderService"]
        PS1["PaymentService"]
        Stripe1["Stripe Gateway"]
        Queue1["Webhook Queue"]

        OS1 -->|1. Charge Card<br/>HTTP Sync| PS1
        PS1 -->|2. Success/Failure<br/>HTTP Response| OS1
        PS1 -->|3. Async Charge<br/>Later| Stripe1
        Stripe1 -.->|4. Webhook Callback<br/>Async| Queue1
        Queue1 -->|5. Notify Order| OS1
    end

    style Solution1 fill:#e8ffe8
    style OS1 fill:#fff
    style PS1 fill:#fff
    style Queue1 fill:#ffffcc


%% ==========================================
%% SOLUTION 2: Sequence Diagram (Temporal Flow)
%% ==========================================

graph TD
    subgraph Solution2["✅ SOLUTION 2: Sequence Diagram (Shows Temporal Flow)"]
        direction TB
        Step1["1. Client → OrderService: PlaceOrder"]
        Step2["2. OrderService → PaymentService: ChargeCard"]
        Step3["3. PaymentService ← ChargeCard Response"]
        Step4["4. [Async Later...]"]
        Step5["5. Stripe → PaymentService: Webhook"]
        Step6["6. PaymentService → OrderService: PaymentProcessed Event"]
    end

    style Solution2 fill:#e8f4ff
    Step1 --> Step2 --> Step3 --> Step4 --> Step5 --> Step6

    Note2["This shows WHEN things happen<br/>and in what order<br/>(temporal causality)"]
    style Note2 fill:#cce8ff,color:#000


%% ==========================================
%% Key Takeaway
%% ==========================================

Summary["
WHEN YOU SEE: A <--> B (bidirectional)
ASK: What is A actually asking B to do?
FIX:  Split into A → B (sync) and B → A (async callback)
OR:   Use sequence diagram to show the temporal flow clearly
"]

style Summary fill:#fff9e6,color:#000
