flowchart TD
    subgraph Customer["👤 Customer"]
        A["Browse Products"]
        B["Add to Cart"]
        C["Proceed to Checkout"]
        D{Confirm Order?}
        E["Receive Confirmation"]
        F["Track Shipment"]
    end

    subgraph OrderService["📦 Order Processing"]
        G["Create Order"]
        H{Validate Order}
        I["Publish OrderCreated Event"]
    end

    subgraph PaymentService["💳 Payment Service"]
        J["Consume OrderCreated"]
        K["Charge Payment Method"]
        L{Payment Success?}
        M["Publish PaymentProcessed Event"]
        N["Publish PaymentFailed Event"]
    end

    subgraph InventoryService["📊 Inventory"]
        O["Consume OrderCreated"]
        P["Reserve Stock"]
        Q{Stock Available?}
        R["Publish StockReserved Event"]
        S["Publish OutOfStock Event"]
    end

    subgraph ShippingService["🚚 Shipping"]
        T["Consume PaymentProcessed"]
        U["Create Shipment"]
        V["Generate Tracking Number"]
        W["Publish ShipmentCreated Event"]
    end

    %% Customer flow
    A --> B --> C --> D
    D -->|No| A
    D -->|Yes| G

    %% Order Processing
    G --> H
    H -->|Invalid| D
    H -->|Valid| I

    %% Parallel flows after OrderCreated event
    I --> J
    I --> O

    %% Payment processing
    J --> K
    K --> L
    L -->|Failed| N
    L -->|Success| M

    %% Inventory processing
    O --> P
    P --> Q
    Q -->|No Stock| S
    Q -->|Available| R

    %% Only proceed to shipping if payment succeeded
    M --> T
    T --> U
    U --> V
    V --> W

    %% Complete order and shipment
    R --> W
    W --> F

    %% Failure paths
    N -.->|Error| E
    S -.->|Backorder| E

    %% Styling
    style Customer fill:#e8f4ff,stroke:#0066cc,stroke-width:2px
    style OrderService fill:#e8e8ff,stroke:#6b6bff,stroke-width:2px
    style PaymentService fill:#ffe8e8,stroke:#ff6b6b,stroke-width:2px
    style InventoryService fill:#e8ffe8,stroke:#6bff6b,stroke-width:2px
    style ShippingService fill:#fff8e8,stroke:#ffb366,stroke-width:2px

    style D fill:#ffcccc
    style H fill:#ffcccc
    style L fill:#ffcccc
    style Q fill:#ffcccc

    style E fill:#ccffcc
    style F fill:#ccffcc
