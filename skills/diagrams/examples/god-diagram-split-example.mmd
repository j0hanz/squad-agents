---
config:
  theme: base
  themeVariables:
    primaryColor: '#e8f4f8'
    primaryTextColor: '#000'
    primaryBorderColor: '#5dd8ff'
    lineColor: '#5dd8ff'
    secondBkgColor: '#f0f0f0'
    tertiaryColor: '#fff'
---

%% CONTEXT LEVEL (L1) - Simplified Overview
%% This is what you show first: high-level system boundaries

graph TB
    User["👤 User"]
    App["🏢 SaaS Platform"]
    Stripe["💳 Stripe (Payment)"]
    Auth0["🔐 Auth0 (Identity)"]
    Twilio["📱 Twilio (SMS/Email)"]

    User -->|Login, Browse, Checkout| App
    App -->|Charge Card| Stripe
    App -->|Verify User| Auth0
    App -->|Send Notifications| Twilio

    style User fill:#e8f8e8
    style App fill:#e8e8ff
    style Stripe fill:#ffe8e8
    style Auth0 fill:#fff8e8
    style Twilio fill:#f8e8ff


%% ==========================================
%% COMPONENT LEVEL (L2) - Multiple Diagrams
%% ==========================================

%% L2-1: Order Processing Component
graph TB
    subgraph OrderDomain["📦 Order Processing Domain"]
        APIGateway["API Gateway"]
        OrderService["OrderService"]
        OrderDB["OrderDB (PostgreSQL)"]
        OrderQueue["OrderQueue (RabbitMQ)"]
    end

    APIGateway -->|Route /orders| OrderService
    OrderService -->|Store Order| OrderDB
    OrderService -->|Publish OrderCreated| OrderQueue

    style OrderDomain fill:#e8e8ff
    style APIGateway fill:#fff
    style OrderQueue fill:#ffffcc


%% L2-2: Payment Component
graph TB
    subgraph PaymentDomain["💳 Payment Domain"]
        PaymentQueue["PaymentQueue (RabbitMQ)"]
        PaymentService["PaymentService"]
        PaymentDB["PaymentDB (PostgreSQL)"]
        StripeAdapter["Stripe Adapter"]
    end

    PaymentQueue -->|Consume OrderCreated| PaymentService
    PaymentService -->|Log Payment| PaymentDB
    PaymentService -->|Charge Card| StripeAdapter
    StripeAdapter -->|API Call| Stripe["Stripe API"]

    style PaymentDomain fill:#ffe8e8
    style StripeAdapter fill:#ffcccc


%% L2-3: Inventory Component
graph TB
    subgraph InventoryDomain["📊 Inventory Domain"]
        InventoryQueue["InventoryQueue (RabbitMQ)"]
        InventoryService["InventoryService"]
        InventoryDB["InventoryDB (PostgreSQL)"]
    end

    InventoryQueue -->|Consume OrderCreated| InventoryService
    InventoryService -->|Decrement Stock| InventoryDB
    InventoryService -->|Publish StockDecremented| ResultQueue["ResultQueue"]

    style InventoryDomain fill:#e8ffe8


%% Key Lessons:
%% 1. L1 (Context): Only Person, System, External Systems
%% 2. L2 (Components): One domain per diagram, max 10 nodes each
%% 3. Queues shown EXPLICITLY (not direct arrows between services)
%% 4. Each diagram is readable without line crossing
