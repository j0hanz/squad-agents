sequenceDiagram
    participant Client
    participant OrderService as OrderService<br/>(Orchestrator)
    participant PaymentService
    participant InventoryService
    participant ShippingService

    Client->>OrderService: PlaceOrder(items, card)
    Note over OrderService: Initiate saga<br/>transaction

    OrderService->>PaymentService: ChargeCard(amount)
    activate PaymentService

    alt Payment Success
        PaymentService-->>OrderService: ✓ Charged
        deactivate PaymentService

        OrderService->>InventoryService: DecrementStock(items)
        activate InventoryService

        alt Inventory Available
            InventoryService-->>OrderService: ✓ Stock Decremented
            deactivate InventoryService

            OrderService->>ShippingService: CreateShipment(address)
            activate ShippingService
            ShippingService-->>OrderService: ✓ Shipment Created
            deactivate ShippingService

            OrderService-->>Client: ✓ Order Confirmed
            Note over Client,OrderService: Happy path complete

        else Inventory Out of Stock
            InventoryService-->>OrderService: ✗ Out of Stock
            deactivate InventoryService

            Note over OrderService: COMPENSATE:<br/>Refund payment

            OrderService->>PaymentService: RefundPayment(chargeId)
            activate PaymentService
            PaymentService-->>OrderService: ✓ Refunded
            deactivate PaymentService

            OrderService-->>Client: ✗ Order Failed<br/>(Insufficient inventory)
            Note over Client,OrderService: Compensation complete
        end

    else Payment Declined
        PaymentService-->>OrderService: ✗ Declined<br/>(Insufficient funds)
        deactivate PaymentService

        OrderService-->>Client: ✗ Order Failed<br/>(Payment declined)
        Note over Client,OrderService: No compensation needed<br/>(nothing charged yet)
    end

    Note over OrderService: Final state recorded
