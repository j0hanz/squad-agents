{
  "name": "squad-agents",
  "version": "1.1.6",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "node bin/validate-plugin.mjs",
    "version": "node bin/sync-manifest-version.mjs",
    "postversion": "git push && git push --tags",
    "test:node": "node --test tests/validate-plugin.test.mjs",
    "test:python": "python -m pytest -q",
    "test": "npm run validate && npm run test:node && npm run test:python",
    "test:integration": "node --test tests/integration/",
    "test:eval": "bash tests/skill-triggering/run-all.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.8.4"
  }
}
