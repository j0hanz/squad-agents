{
  "description": "Lifecycle hooks for squad-agents: a shell-safety guard and a skill nudge. Bash-only — see hooks/*.sh.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/shell-safety.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/skill-nudge.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
